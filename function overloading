#include <iostream>
using namespace std;

// Function with 2 integer parameters
int add(int a, int b) {
    return a + b;
}

// Function with 3 integer parameters
int add(int a, int b, int c) {
    return a + b + c;
}

// Function with float parameters
float add(float a, float b) {
    return a + b;
}

int main() {
    cout << "Sum of 2 integers: " << add(2, 3) << endl;
    cout << "Sum of 3 integers: " << add(2, 3, 4) << endl;
    cout << "Sum of floats: " << add(2.5f, 3.5f) << endl;

    return 0;
}

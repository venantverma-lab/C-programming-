#include <iostream>
using namespace std;

class Student {
public:
    int roll;
    string name;

    // Constructor
    Student() {
        roll = 0;
        name = "Default";
    }

    void display() {
        cout << "Roll: " << roll << endl;
        cout << "Name: " << name << endl;
    }
};

int main() {
    Student s1;   // Constructor is automatically called
    s1.display();

    return 0;
}
